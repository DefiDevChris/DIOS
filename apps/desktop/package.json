{
  "name": "@dios/desktop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "electron .",
    "build": "vite build",
    "build:main": "esbuild main/index.ts --bundle --platform=node --format=esm --outfile=dist-electron/main/index.js --external:electron --external:better-sqlite3 --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\" && esbuild main/preload.ts --bundle --platform=node --format=cjs --outfile=dist-electron/main/preload.js --external:electron",
    "build:electron": "npm run build:main && npm run build && electron-rebuild -f -w better-sqlite3 && electron-builder",
    "generate-icons": "bash scripts/generate-icons.sh",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron out",
    "lint": "tsc --noEmit",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@dios/shared": "*",
    "better-sqlite3": "^11.0.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.6",
    "electron-updater": "^6.3.9",
    "idb": "^8.0.3",
    "jspdf": "^4.2.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "papaparse": "^5.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "react-router": "^7.13.1",
    "recharts": "^3.8.0",
    "sweetalert2": "^11.26.22",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/dompurify": "^3.2.0",
    "@types/gapi": "^0.0.47",
    "@types/gapi.client.calendar": "^3.0.12",
    "@types/gapi.client.drive": "^3.0.15",
    "@types/gapi.client.drive-v3": "^0.0.5",
    "@types/gapi.client.gmail": "^1.0.5",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "electron": "36.9.5",
    "electron-builder": "^26.0.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^8.0.0"
  }
}

# DIOS Studio configuration
# Copy this file to .env and fill in your values.
# See the SetupWizard for guided setup.

# Google OAuth Client ID (Web application type from GCP Console)
GOOGLE_OAUTH_CLIENT_ID=

# Google Maps API Key (for Places Autocomplete - enable Places API in GCP Console)
GOOGLE_MAPS_API_KEY=

# Firebase Configuration (from Firebase Console -> Project Settings -> Web app)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
